# Octavi IFR-1 — grant the logged-in user access to the HID device so ifrbridge
# can run without root. Covers both the hidraw and libusb hidapi backends.
# Install to /etc/udev/rules.d/ then: udevadm control --reload-rules && udevadm trigger
KERNEL=="hidraw*", ATTRS{idVendor}=="04d8", ATTRS{idProduct}=="e6d6", TAG+="uaccess", MODE="0660"
SUBSYSTEM=="usb", ATTRS{idVendor}=="04d8", ATTRS{idProduct}=="e6d6", TAG+="uaccess", MODE="0660"
